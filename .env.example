# ─── Supabase ──────────────────────────────────────────────────────────────
# Project: qwlhqmynmrmmeakhhgny (Surve)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Service role — server-side only (edge functions). NEVER ship in the client.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Stripe ────────────────────────────────────────────────────────────────
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── Twilio (phone OTP via Verify API) ────────────────────────────────────
# Set these as Supabase edge function secrets:
#   supabase secrets set TWILIO_ACCOUNT_SID=AC... TWILIO_AUTH_TOKEN=... TWILIO_VERIFY_SERVICE_SID=VA...
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Apple (eas submit) ───────────────────────────────────────────────────
# Required for `eas submit --platform ios`. Find these in App Store Connect:
#   ascAppId  → App Store Connect → App → General → App Information → Apple ID
#   appleTeamId → developer.apple.com → Membership Details → Team ID
APPLE_APP_STORE_CONNECT_APP_ID=123456789
APPLE_TEAM_ID=XXXXXXXXXX

# ─── EAS / Expo ───────────────────────────────────────────────────────────
# Required for OTA updates. Run `eas project:init` or copy from expo.dev → project → Settings
EAS_PROJECT_ID=

# ─── Optional ──────────────────────────────────────────────────────────────
EXPO_ACCESS_TOKEN=                 # Expo push-notification send (server)
EXPO_PUBLIC_SENTRY_DSN=            # Crash reporting (optional)
EXPO_PUBLIC_SENTRY_DEBUG=0         # Set to 1 to capture in __DEV__
EXPO_PUBLIC_USE_MOCK_FALLBACK=true # Fall back to mockData when DB is empty
